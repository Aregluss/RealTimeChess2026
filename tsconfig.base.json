{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@realtimechess/shared-types": ["packages/shared-types/src/index.ts"],
      "@realtimechess/game-engine": ["packages/game-engine/src/index.ts"],
      "@realtimechess/server-core": ["packages/server-core/src/index.ts"]
    }
  }
}
